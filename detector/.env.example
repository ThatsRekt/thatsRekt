# Otomato API key (sk_live_... or sk_test_...). Required for deploy + check.
# Set OTOMATO_API_URL only if pointing at a non-prod Otomato instance.
OTOMATO_API_KEY=
OTOMATO_API_URL=https://api.otomato.xyz/api

# Relay webhook target — the public URL that Otomato will POST detections
# to. For local dev this is typically your ngrok / cloudflared URL with
# /detect appended. Example: https://abcd-1234.ngrok-free.app
WEBHOOK_BASE_URL=

# Bearer token the relay expects. Must match RELAY_PROVIDER_TOKEN on the
# running relay process. Treat as a shared secret.
WEBHOOK_TOKEN=

# Chain the relay is configured to submit to. Single-chain for v1 of the
# detector; matches RELAY_CHAIN_NAME on the relay.
WEBHOOK_CHAIN=anvil-eth
