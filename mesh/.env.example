# --- Mesh gateway -----------------------------------------------------------
PORT=4350
MESH_CHAINS=base,base-sepolia,optimism

# Per-chain upstream squid GraphQL endpoints. Defaults match the compose
# service names in damm-cloud/thatsrekt/public/docker-compose.yml.
GRAPHQL_BASE_URL=http://graphql-base:4353/graphql
GRAPHQL_BASE_SEPOLIA_URL=http://graphql-base-sepolia:4361/graphql
GRAPHQL_OPTIMISM_URL=http://graphql-optimism:4355/graphql

# --- Off-chain comments DB --------------------------------------------------
# Postgres URL for the shared `thatsrekt_meta` database. The database is
# created by deploy.sh's bootstrap step (replays CREATE DATABASE lines from
# init.sql idempotently); Mesh only needs the connection string.
META_DB_URL=postgres://postgres:postgres@db:5432/thatsrekt_meta
