# =============================================================================
# thatsRekt indexer — environment configuration
# =============================================================================
# Copy to .env and fill in real values. The chain registry (src/chains.ts)
# is the source of truth — every per-chain env var below has a matching
# entry there. Mesh-side defaults match the docker-compose service names,
# so the bare-minimum local-dev setup is just `ANVIL_ETH_FORK_URL` +
# `ANVIL_BASE_FORK_URL` and the bootstrap script.
# =============================================================================

# --- Postgres ----------------------------------------------------------------
DB_USER=postgres
DB_PASS=postgres
DB_HOST=localhost
DB_PORT=5432

# --- Chains -------------------------------------------------------------------
# Each chain has its own processor + graphql + database, all named by slug:
#
#     CHAIN          chainId    purpose
#     -------------  ---------  ------------------------------------------------
#     anvil-eth      31337      Local Anvil fork of Ethereum mainnet (instant)
#     anvil-base     31338      Local Anvil fork of Base mainnet     (instant)
#     sepolia        11155111   Real Ethereum Sepolia
#     base           8453       Real Base mainnet
#     optimism       10         Real Optimism mainnet
#
# Two anvil forks running side-by-side are the local cross-chain testbed:
# deploy thatsRekt to both (DeployDev with the same EOA → same CREATE2
# proxy address on both), index both, watch the unified Mesh feed merge.
# No real testnet ETH or routeme.sh keys required for the anvil-* chains.

# Anvil — Ethereum mainnet fork (chainId 31337). Forks chainId=1.
RPC_ANVIL_ETH_HTTP=http://anvil-eth:8545
CONTRACT_ANVIL_ETH=0x0000000000000000000000000000000000000000
START_BLOCK_ANVIL_ETH=0
ANVIL_ETH_FORK_URL=https://lb.routeme.sh/rpc/1/REPLACE_WITH_ROUTEME_KEY

# Anvil — Base fork (chainId 31338)
RPC_ANVIL_BASE_HTTP=http://anvil-base:8545
CONTRACT_ANVIL_BASE=0x0000000000000000000000000000000000000000
START_BLOCK_ANVIL_BASE=0
ANVIL_BASE_FORK_URL=https://lb.routeme.sh/rpc/8453/REPLACE_WITH_ROUTEME_KEY

# Real Ethereum Sepolia (chainId 11155111)
RPC_SEPOLIA_HTTP=https://lb.routeme.sh/rpc/11155111/REPLACE_WITH_ROUTEME_KEY
CONTRACT_SEPOLIA=0x0000000000000000000000000000000000000000
START_BLOCK_SEPOLIA=0

# Real Base mainnet (chainId 8453)
RPC_BASE_HTTP=https://lb.routeme.sh/rpc/8453/REPLACE_WITH_ROUTEME_KEY
CONTRACT_BASE=0x0000000000000000000000000000000000000000
START_BLOCK_BASE=0

# Real Optimism mainnet (chainId 10)
RPC_OPTIMISM_HTTP=https://lb.routeme.sh/rpc/10/REPLACE_WITH_ROUTEME_KEY
CONTRACT_OPTIMISM=0x0000000000000000000000000000000000000000
START_BLOCK_OPTIMISM=0

# --- Mesh gateway -------------------------------------------------------------
# Comma-separated list of slugs Mesh will stitch. For local-only cross-chain
# testing without any external RPCs, set: anvil-eth,anvil-base
MESH_CHAINS=anvil-eth,anvil-base,sepolia,base,optimism
MESH_PORT=4350
