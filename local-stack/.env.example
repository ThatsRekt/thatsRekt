# =============================================================================
# thatsRekt local stack — environment template.
# =============================================================================
# Copy to .env and fill in the placeholders before `docker compose up`.
#
#   cp .env.example .env
#   $EDITOR .env
#
# Every var listed here is consumed directly by docker-compose.yml. No AWS
# Secrets Manager pull, no SSM — local only.
# =============================================================================

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=postgres
# CHANGE THIS before running. Any non-empty value works locally — postgres
# will bootstrap with whatever you put here. Doesn't need to match prod.
POSTGRES_PASSWORD=local-thatsrekt-password

# --- ECR image source -------------------------------------------------------
# Default points at DAMM's prod ECR. If you have ECR access (admin profile)
# and have run `aws ecr get-login-password ... | docker login ...` (see
# README), the `:latest` images will pull straight from there.
# ECR_REGISTRY=465910372065.dkr.ecr.us-west-2.amazonaws.com
# IMAGE_TAG=latest

# --- Subsquid archive gateway for Base Sepolia -----------------------------
# Public Subsquid archive endpoint — no key required.
ARCHIVE_BASE_SEPOLIA=https://v2.archive.subsquid.io/network/base-sepolia

# --- Public RPC for Base Sepolia -------------------------------------------
# Public endpoint, no API key needed for low-volume local indexing.
RPC_BASE_SEPOLIA=https://sepolia.base.org

# --- Contract address (Base Sepolia proxy) ---------------------------------
# Paste the proxy address from the most recent Sepolia deploy here.
CONTRACT_BASE_SEPOLIA=0x_REPLACE_ME_PASTE_SEPOLIA_PROXY

# --- Block where the contract was deployed ---------------------------------
# Read this off the Foundry broadcast output (`broadcast/.../run-latest.json`)
# or the deploy subagent's report.
START_BLOCK_BASE_SEPOLIA=_REPLACE_ME_

# --- Mesh chain registry ----------------------------------------------------
# The local stack only stitches base-sepolia. If you add another chain to
# docker-compose.yml later, append it here (comma-separated).
MESH_CHAINS=base-sepolia
