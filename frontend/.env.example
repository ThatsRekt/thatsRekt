# GraphQL endpoint the frontend queries (Mesh gateway).
#
# Optional. When unset, the frontend computes the endpoint at runtime from
# `window.location.hostname` + `:4350`. That means the same build works for:
#   - localhost dev:  http://localhost:5173  → http://localhost:4350/graphql
#   - LAN dev:        http://192.168.1.42:5173 → http://192.168.1.42:4350/graphql
#   - Future hosted:  dynamic per-deployment, no rebuild needed.
#
# Set this only if you need to override the default (e.g. point at a remote
# Mesh gateway from your dev frontend).
# VITE_GRAPHQL_ENDPOINT=http://localhost:4350/graphql

# When true, the frontend ignores the GraphQL endpoint and serves a built-in
# dummy dataset (see src/lib/mock.ts). Useful for first-run UI inspection,
# screenshots, and design iteration without spinning up the indexer stack.
# A persistent banner is shown across all pages while this is on.
VITE_USE_MOCK_DATA=false

# When true, the chain selector + contributors page surface the local
# Anvil forks (anvil-eth, anvil-base) alongside real chains. Default is
# false — production builds hide local forks since end users have no
# use for chains that don't exist outside one developer's machine. Set
# to `true` in `.env.local` for dev.
VITE_SHOW_LOCAL_FORKS=false
