# =============================================================================
# thatsRekt indexer — environment configuration
# =============================================================================
# Copy to .env and fill in real values. The indexer is multichain-ready: a
# single CHAIN env picks which chain a given processor instance indexes.
# The chain registry (src/chains.ts) is the source of truth — names of the
# per-chain env vars below are declared there.
# =============================================================================

# --- Postgres ----------------------------------------------------------------
# Used by both the processor and the GraphQL server.
DB_NAME=squid
DB_USER=postgres
DB_PASS=postgres
DB_HOST=localhost
DB_PORT=5432

# --- GraphQL server ----------------------------------------------------------
GQL_PORT=4350

# --- Chain selector ----------------------------------------------------------
# Which chain this processor instance is for. One of: anvil | sepolia | base.
# (Phase 2 will run multiple processor instances in parallel — one per chain —
# from the same image, each with its own CHAIN value.)
CHAIN=base

# --- Per-chain configuration -------------------------------------------------
# Only the block matching CHAIN is required at runtime. The others can stay
# blank or be commented out. Filling them in makes future chain switches a
# matter of changing CHAIN — no other env edits needed.

# Base mainnet (chainId 8453)
# RPC: prefer routeme.sh (load-balanced multi-provider, used by all DAMM services).
# Pattern: https://lb.routeme.sh/rpc/{chainId}/{api-key}
# Get the api-key from DAMM secrets — do NOT commit it.
RPC_BASE_HTTP=https://lb.routeme.sh/rpc/8453/REPLACE_WITH_ROUTEME_KEY
CONTRACT_BASE=0x0000000000000000000000000000000000000000
START_BLOCK_BASE=0

# Ethereum Sepolia (chainId 11155111)
# Filled in once Phase 3 deploys thatsRekt to Sepolia.
RPC_SEPOLIA_HTTP=https://lb.routeme.sh/rpc/11155111/REPLACE_WITH_ROUTEME_KEY
CONTRACT_SEPOLIA=0x0000000000000000000000000000000000000000
START_BLOCK_SEPOLIA=0

# Anvil — local fork of Sepolia (chainId 31337)
# Filled in by the Phase 4 bootstrap script. The RPC URL points at the
# anvil docker service from inside the compose network.
RPC_ANVIL_HTTP=http://anvil:8545
CONTRACT_ANVIL=0x0000000000000000000000000000000000000000
START_BLOCK_ANVIL=0
