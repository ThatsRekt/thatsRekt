{
  "name": "thatsrekt-indexer",
  "version": "0.1.0",
  "description": "Subsquid indexer for the thatsRekt on-chain hack alert registry. Indexes contract events and exposes a GraphQL API.",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf lib && tsc",
    "process": "node lib/main.js",
    "process:dev": "tsc-watch --onSuccess 'node lib/main.js'",
    "serve": "squid-graphql-server",
    "db:migrate": "squid-typeorm-migration apply",
    "db:create": "squid-typeorm-migration generate",
    "db:reset": "squid-typeorm-migration revert -a",
    "codegen:schema": "squid-typeorm-codegen",
    "codegen:abi": "squid-evm-typegen src/abi abi/ThatsRekt.json",
    "codegen": "pnpm codegen:schema && pnpm codegen:abi"
  },
  "dependencies": {
    "@subsquid/evm-abi": "0.3.1",
    "@subsquid/evm-codec": "0.3.0",
    "@subsquid/evm-processor": "1.29.1",
    "@subsquid/graphql-server": "4.12.0",
    "@subsquid/typeorm-migration": "1.3.1",
    "@subsquid/typeorm-store": "1.9.0",
    "dotenv": "16.4.7",
    "pg": "8.13.1",
    "typeorm": "0.3.21"
  },
  "devDependencies": {
    "@subsquid/evm-typegen": "4.6.0",
    "@subsquid/typeorm-codegen": "2.2.0",
    "@types/node": "22.13.4",
    "tsc-watch": "6.2.1",
    "typescript": "5.7.3"
  }
}
