# Postgres (used by both the processor and the GraphQL server).
DB_NAME=squid
DB_USER=postgres
DB_PASS=postgres
DB_HOST=localhost
DB_PORT=5432

# GraphQL server.
GQL_PORT=4350

# Processor — Base mainnet (the v0.1 testing chain). Set CONTRACT_ADDRESS + START_BLOCK
# once thatsRekt is deployed.
#
# RPC: prefer routeme.sh (load-balanced multi-provider, used by all DAMM services).
# Pattern: https://lb.routeme.sh/rpc/{chainId}/{api-key}
# Base mainnet chainId = 8453. Get the api-key from DAMM secrets — do NOT commit it.
RPC_BASE_HTTP=https://lb.routeme.sh/rpc/8453/REPLACE_WITH_ROUTEME_KEY
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
START_BLOCK=0
