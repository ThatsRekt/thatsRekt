# =============================================================================
# donations-indexer — environment configuration
# =============================================================================
# Copy to .env and fill in real values.
# =============================================================================

# --- Ethereum RPC (required) -------------------------------------------------
# Ethereum mainnet RPC endpoint. routeme.sh or any archive-capable provider.
# Subsquid gateway (GATEWAY_URL) is optional but speeds up historical sync;
# for local anvil testing, omit it and rely on RPC-only mode.
RPC_ETHEREUM_HTTP=https://lb.routeme.sh/rpc/1/REPLACE_WITH_ROUTEME_KEY

# Optional: Subsquid Network archive gateway for fast historical sync.
# Omit for anvil testing (no gateway available for local chains).
# GATEWAY_URL=https://v2.archive.subsquid.io/network/eth-mainnet

# --- Donations DB (required) -------------------------------------------------
# PostgreSQL connection string for the donations database.
# The processor creates the schema on first start (ensureDonationTable).
DONATIONS_DB_URL=postgres://postgres:postgres@localhost:5432/thatsrekt_donations

# --- Processor tuning --------------------------------------------------------
# Block to start indexing from. The thatsrekt.eth Safe was deployed in block
# 19000000 on Ethereum mainnet. Override for testing (anvil fork starts later).
START_BLOCK_ETHEREUM=19000000

# Finality confirmation depth in blocks.
# Default 75 (Ethereum PoS justification depth, ~15 min at 12s blocks).
# Set to 0 for local anvil testing to treat all blocks as final.
# FINALITY_CONFIRMATION=75

# --- Donee resolution (ENS) --------------------------------------------------
# The donee (the address thatsrekt.eth resolves to) is resolved at startup by
# reading ENS AddrChanged logs on Ethereum MAINNET — not an eth_call. So every
# chain's processor (base/arbitrum/etc.) needs a mainnet endpoint for this one
# getLogs. Point ENS_RPC_URL at any mainnet RPC (reuse RPC_ETHEREUM_HTTP).
# If unset, the resolver falls back to the seed donee (the gov Safe) and warns —
# it never crashes and never watches the zero address.
ENS_RPC_URL=https://lb.routeme.sh/rpc/1/REPLACE_WITH_ROUTEME_KEY

# Optional escape hatch: pin the donee directly, bypassing ENS resolution.
# Used by the e2e tests (set to the funded Safe) and available for ops if ENS
# resolution ever needs to be overridden. Lowercased internally.
# DONEE_OVERRIDE=0x59E4DBc95BD312A882Bb36b7f3E8298682340679
#
# Note: the seed/fallback donee (DONEE_SEED, the current gov Safe) is a code
# constant in main.ts, not an env var — it's the address used when ENS
# resolution yields nothing.

# --- Test environment --------------------------------------------------------
# The following variables are only needed when running tests (bun test).
# They are NOT used by the processor itself.

# TEST_DB_URL — test database for e2e tests.
# Must point to a Postgres instance where the test harness can create a DB.
# Default: postgres://postgres:postgres@localhost:5432/donations_test
# TEST_DB_URL=postgres://postgres:postgres@localhost:5432/donations_test

# TEST_SUPERUSER_URL — superuser connection used to CREATE DATABASE for tests.
# Must have CREATE DATABASE privilege on the Postgres server.
# Default: postgres://postgres:postgres@localhost:5432/postgres
# TEST_SUPERUSER_URL=postgres://postgres:postgres@localhost:5432/postgres

# TEST_ERC20_DB_URL — separate test DB for the ERC20 e2e test.
# Used to avoid table collisions with the native ETH e2e test when both run
# concurrently. Falls back to the same server as TEST_SUPERUSER_URL.
# Default: postgres://postgres:postgres@localhost:5432/donations_erc20_test
# TEST_ERC20_DB_URL=postgres://postgres:postgres@localhost:5432/donations_erc20_test

# FORK_URL — Ethereum archive RPC for the ERC20 e2e test (mainnet fork).
# Required only for test/processor.erc20.e2e.test.ts. Falls back to
# RPC_ETHEREUM_HTTP if set. Must be an archive-capable endpoint.
# FORK_URL=https://lb.routeme.sh/rpc/1/REPLACE_WITH_ROUTEME_KEY
