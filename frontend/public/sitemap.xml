<?xml version="1.0" encoding="UTF-8"?>
<!--
  Static sitemap covering the SPA shell routes. Per-post pages
  (`/post/:chain/:postId`) are dynamic and minted whenever a
  whitelisted poster fires a `post(...)` tx; a future revision
  will have Mesh generate the per-post entries from the indexer
  data so this file lists every active post too.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://thatsrekt.com/</loc>
    <changefreq>hourly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://thatsrekt.com/about</loc>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://thatsrekt.com/posters</loc>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>
  <url>
    <loc>https://thatsrekt.com/docs</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
</urlset>
