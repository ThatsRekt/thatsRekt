{
  "name": "guardian-apply-bot",
  "version": "0.1.0",
  "description": "Single-run service that claims unforwarded guardian applications from thatsrekt_meta and posts them to a private Telegram channel exactly once.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf lib && tsc",
    "typecheck": "tsc --noEmit",
    "start": "node lib/index.js",
    "dev": "tsx src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "pg": "8.13.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/bun": "1.1.14",
    "@types/node": "22.13.4",
    "@types/pg": "8.11.10",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
